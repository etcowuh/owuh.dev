---
export const prerender = true;
import Layout from "@/layouts/Layout.astro";
import { Home } from "lucide-react";
---

<Layout title="Yearbook Quote">
  <div class="min-h-[calc(100vh-12rem)] flex flex-col">
    <div class="flex-1 flex items-center justify-center p-8">
      <div class="flex flex-col items-center text-center max-w-md relative">
        <h2 class="text-4xl tracking-tight font-semibold text-foreground mb-2">
          Yearbook Quote
        </h2>
        <p class="text-muted-foreground mb-8 text-balance tracking-tight font-medium">
          They said I wasn't allowed to speak my mind, unfortunately for them, I have a website and know hexadecimal.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
        </div>
      </div>
    </div>
  </div>
</Layout>
